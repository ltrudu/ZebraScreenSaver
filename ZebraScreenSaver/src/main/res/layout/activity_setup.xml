<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".SetupActivity">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <TextView
            android:id="@+id/txtServiceSettings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_centerHorizontal="false"
            android:layout_marginTop="10dp"
            android:gravity="center"
            android:text="Service Settings"
            android:textSize="24sp"
            android:visibility="visible" />

        <View
            android:id="@+id/vSeparator0"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginBottom="10dp"
            android:layout_marginTop="10dp"
            android:background="@android:color/darker_gray"
            android:layout_below="@+id/txtServiceSettings"
            />

        <Switch
            android:id="@+id/swStartStopServiceSwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="10dp"
            android:layout_marginTop="10dp"
            android:layout_marginRight="10dp"
            android:text="Start Service"
            android:layout_below="@+id/vSeparator0"
            android:textSize="24sp" />
    <Switch
        android:id="@+id/swStartOnBootSwitch"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@+id/swStartStopServiceSwitch"
        android:layout_marginLeft="10dp"
        android:layout_marginTop="10dp"
        android:layout_marginRight="10dp"
        android:text="Auto-start after reboot"
        android:textSize="24sp" />

        <Switch
            android:id="@+id/swStartOnCraddle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@+id/swStartOnBootSwitch"
            android:layout_marginLeft="10dp"
            android:layout_marginTop="10dp"
            android:layout_marginRight="10dp"
            android:text="Start on craddle"
            android:textSize="24sp"
            android:visibility="visible" />

        <View
            android:id="@+id/vSeparator1"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginBottom="10dp"
            android:layout_marginTop="10dp"
            android:background="@android:color/darker_gray"
            android:layout_below="@+id/swStartOnCraddle"
            />

        <TextView
            android:id="@+id/txtScreenSaverSettings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_centerHorizontal="false"
            android:gravity="center"
            android:layout_below="@+id/vSeparator1"
            android:text="ScreenSaver Settings"
            android:textSize="24sp"
            android:visibility="visible" />
        <View
            android:id="@+id/vSeparator2"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginBottom="10dp"
            android:layout_marginTop="10dp"
            android:background="@android:color/darker_gray"
            android:layout_below="@+id/txtScreenSaverSettings"
            />

        <TextView
            android:id="@+id/txtCurrentTimeOut"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@+id/vSeparator2"
            android:layout_marginLeft="10dp"
            android:layout_marginRight="10dp"
            android:text="Timeout:"
            android:textSize="24sp"
            android:visibility="visible" />

        <SeekBar
            android:id="@+id/sbTimeout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@+id/txtCurrentTimeOut"
            android:layout_marginTop="10dp"
            android:scrollbarSize="20dp" />


    </RelativeLayout>
</ScrollView>