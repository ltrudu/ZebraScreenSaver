<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/rlOverlay"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <View
        android:id="@+id/rootbackground"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#000000"></View>

    <View
        android:id="@+id/vcustombackground"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/background"></View>

    <RelativeLayout
        android:id="@+id/rlMovingOverlay"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content">

        <TextView
            android:id="@+id/overlayText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerHorizontal="true"
            android:fontFamily="@font/crooked_hooks"
            android:text="SCANNEZ LE PRODUIT\nPOUR CONNAITRE\n SON PRIX !"
            android:textAlignment="center"
            android:textColor="#FFFFFF"
            android:textSize="180dp" />

        <ImageView
            android:id="@+id/imageView2"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_below="@id/overlayText"
            android:layout_centerInParent="true"
            app:srcCompat="@drawable/chevrons" />

    </RelativeLayout>

</RelativeLayout>